build/
.DS_Store

.pio/

# Python
venv/
__pycache__/
*.pyc
*.pyo

# Node.js
node_modules/
package-lock.json

# Editor
.vscode/
.idea/
*.swp
*.swo

# Large datasets (keep analysis results, ignore raw data)
audio-reactive/research/datasets/

# Effect preferences (user-specific ratings/order, created at runtime)
audio-reactive/effects/effect_prefs.json

# User palettes (custom color mappings, created at runtime)
audio-reactive/effects/user_palettes.json

# Generated analysis plots (regenerable from scripts)
audio-reactive/research/analysis/scripts/*.png

# Audio: all wav files under audio-segments (too large for git)
audio-reactive/research/audio-segments/**/*.wav
!audio-reactive/research/audio-segments/harmonix/*_5s.wav
!audio-reactive/research/audio-segments/harmonix/*_10s.wav

# Audio: separated stems are regenerable (demucs/hpss), never commit
audio-reactive/research/audio-segments/separated/

# Audio: user uploads (test files, temporary)
audio-reactive/research/audio-segments/uploads/

# Search cache (regenerated automatically by tools/search_ledger.py)
*.search_cache.pkl

# Festicorn local credentials
festicorn/src/wifi_credentials_local.h
